---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = (await getCollection("blog")).sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = "Archivo — Humanoides & Asociados";

const categoryColors: Record<string, string> = {
    "caso de estudio": "border-brand-red text-brand-red",
    reflexión: "border-brand-black text-brand-black",
    tutorial: "border-brand-red text-brand-red",
    agencia: "border-brand-black text-brand-black",
};
---

<Layout title={title}>
    <main
        class="w-full bg-brand-gray text-brand-black pt-28 md:pt-36 pb-24 md:pb-32 font-sans"
    >
        <div class="max-w-[1440px] mx-auto px-6">
            <!-- Section Header — ghost number pattern (consistent with rest of site) -->
            <header class="mb-12 md:mb-16">
                <h1
                    class="font-sans font-100 uppercase leading-none tracking-tighter text-brand-red"
                    style="font-size: clamp(2.5rem, 7vw, 7rem); letter-spacing: -0.04em;"
                >
                    Archivo
                </h1>

                <p
                    class="font-sans font-400 text-brand-black mt-4 max-w-lg"
                    style="font-size: clamp(0.95rem, 1.5vw, 1.25rem); line-height: 1.4;"
                >
                    Reflexiones, casos y señales del estudio.
                </p>
            </header>

            <!-- Posts Table -->
            <section aria-label="Lista de publicaciones">
                <!-- Table Header (Desktop) -->
                <div
                    class="hidden md:grid grid-cols-12 gap-0 border-y-2 border-brand-black py-3 text-[10px] uppercase font-bold tracking-[0.3em] text-brand-red"
                >
                    <div class="col-span-2 px-4">Fecha</div>
                    <div class="col-span-7 px-4">Asunto</div>
                    <div class="col-span-2 px-4">Categoría</div>
                    <div class="col-span-1 px-4 text-right">Autor</div>
                </div>

                <!-- Posts List -->
                <div class="flex flex-col">
                    {
                        posts.map((post) => {
                            const category = (
                                post.data.tags?.[0] || "reflexión"
                            ).toLowerCase();
                            const colorClass =
                                categoryColors[category] ||
                                "border-brand-black text-brand-black";

                            return (
                                <a
                                    href={`/blog/${post.slug}`}
                                    class="group block"
                                >
                                    <div
                                        class="grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-0 py-6 md:py-5 border-b border-brand-black hover:bg-brand-red hover:text-brand-gray items-baseline"
                                        style="transition: background 0.08s linear, color 0.08s linear;"
                                    >
                                        {/* FECHA */}
                                        <div class="col-span-12 md:col-span-2 px-0 md:px-4 text-[10px] uppercase tracking-[0.2em] font-bold text-brand-red group-hover:text-brand-gray">
                                            <time
                                                datetime={post.data.pubDate.toISOString()}
                                            >
                                                {post.data.pubDate.toLocaleDateString(
                                                    "es-ES",
                                                    {
                                                        year: "numeric",
                                                        month: "2-digit",
                                                        day: "2-digit",
                                                    },
                                                )}
                                            </time>
                                        </div>

                                        {/* ASUNTO */}
                                        <div class="col-span-12 md:col-span-7 px-0 md:px-4">
                                            <h2
                                                class="font-sans font-900 uppercase tracking-tight leading-none group-hover:text-brand-gray"
                                                style="font-size: clamp(1.25rem, 2.5vw, 2rem);"
                                            >
                                                {post.data.title}
                                            </h2>
                                            {post.data.description && (
                                                <p class="text-sm mt-2 font-sans font-400 text-brand-black group-hover:text-brand-gray leading-snug max-w-xl">
                                                    {post.data.description}
                                                </p>
                                            )}
                                        </div>

                                        {/* CATEGORÍA */}
                                        <div class="col-span-12 md:col-span-2 px-0 md:px-4 mt-2 md:mt-0">
                                            <span
                                                class={`inline-block text-[9px] uppercase tracking-[0.2em] font-bold px-3 py-1 border group-hover:border-brand-gray group-hover:text-brand-gray ${colorClass}`}
                                            >
                                                {category}
                                            </span>
                                        </div>

                                        {/* AUTOR */}
                                        <div class="hidden md:block col-span-1 px-4 text-[10px] uppercase tracking-[0.2em] font-bold text-brand-black group-hover:text-brand-gray text-right">
                                            {post.data.author}
                                        </div>
                                    </div>
                                </a>
                            );
                        })
                    }
                </div>
            </section>
        </div>
    </main>
</Layout>
