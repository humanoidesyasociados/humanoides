---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";

interface Props {
  title?: string;
  showNavbar?: boolean;
  showFooter?: boolean;
}

const { title = "HA", showNavbar = true, showFooter = true } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-WDFWL49V");
    </script>
    <!-- End Google Tag Manager -->

    <!-- Google Analytics 4 -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-YESCC5Q2ZC"
      is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-YESCC5Q2ZC");
    </script>
    <!-- End Google Analytics 4 -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {
      (Astro.url.pathname.includes("/preview") ||
        Astro.url.pathname.includes("/projects") ||
        Astro.url.pathname.includes("/brand")) && (
        <meta name="robots" content="noindex, nofollow" />
      )
    }
    <meta
      name="description"
      content="Humanoides & Asociados: Operaciones creativas de alto rendimiento. Fusión de talento humano y agentes de Inteligencia Artificial para el éxito digital."
    />
    <meta
      name="keywords"
      content="operaciones creativas, inteligencia artificial, desarrollo web premium, diseño estratégico, transformación digital avanzada, humanoides"
    />
    <meta name="author" content="Humanoides & Asociados" />
    <link rel="canonical" href={Astro.url} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Operaciones creativas impulsadas por humanos y agentes IA. Diseño y desarrollo de productos digitales con criterio lógico y estético."
    />
    <meta property="og:image" content="/humanoides-logo.svg" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": "https://humanoidesyasociados.com/#israel",
            "name": "Israel",
            "jobTitle": "Director Creativo y Fundador",
            "url": "https://humanoidesyasociados.com",
            "sameAs": ["https://instagram.com/humanoidesyasociados"],
            "nationality": "Peruana"
          },
          {
            "@type": "ProfessionalService",
            "@id": "https://humanoidesyasociados.com/#organization",
            "name": "Humanoides & Asociados",
            "url": "https://humanoidesyasociados.com",
            "logo": "https://humanoidesyasociados.com/humanoides-logo.svg",
            "email": "hola@humanoidesyasociados.com",
            "address": {
              "@type": "PostalAddress",
              "addressCountry": "PE"
            },
            "founder": {
              "@id": "https://humanoidesyasociados.com/#israel"
            },
            "brand": {
              "@id": "https://humanoidesyasociados.com/#organization"
            },
            "priceRange": "$$$",
            "description": "Creative Operations especialistas en diseño y desarrollo web. Fusión de talento humano y agentes IA."
          }
        ]
      }
    </script>

    <!-- Preload Critical Resources -->
    <!-- Preload Hero Image for LCP -->
    <link
      rel="preload"
      as="image"
      href="/hero-bg.webp"
      type="image/webp"
      fetchpriority="high"
    />
    <!-- DNS prefetch for analytics -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Preload Self-Hosted Font -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/anek-malayalam-100-800.woff2"
      crossorigin
    />

    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-WDFWL49V"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    {showNavbar && <Navbar />}
    <slot />
    {showFooter && <Footer />}
    <CookieConsent />

    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      let lenis: Lenis | null = null;

      function initLenis() {
        if (lenis) lenis.destroy();
        lenis = new Lenis();

        function raf(time: number) {
          lenis?.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      // Handle Image Loading (Skeletons)
      function handleImageLoad(img: HTMLImageElement) {
        const wrapper = img.parentElement?.querySelector(
          ".skeleton-wrapper",
        ) as HTMLElement;
        if (wrapper) {
          wrapper.style.opacity = "0";
          img.style.opacity = "1";
          setTimeout(() => {
            wrapper.style.display = "none";
          }, 500);
        }
      }

      function setupGlobalImageHandler() {
        // Handle images already in DOM
        document.querySelectorAll("img[data-transition-img]").forEach((img) => {
          const image = img as HTMLImageElement;
          if (image.complete) {
            handleImageLoad(image);
          } else {
            image.onload = () => handleImageLoad(image);
          }
        });
      }

      document.addEventListener("astro:page-load", () => {
        initLenis();
        setupGlobalImageHandler();

        // Kill only the section-reveal ScrollTriggers, not page-specific ones
        ScrollTrigger.getAll()
          .filter((t) => {
            const el = t.trigger as HTMLElement | null;
            return (
              !el ||
              el.classList.contains("gsap-reveal-section") ||
              !el.closest("#desktop-showcase-container")
            );
          })
          .forEach((t) => t.kill());

        const sections = document.querySelectorAll<HTMLElement>(
          ".gsap-reveal-section",
        );

        if (sections.length > 0) {
          sections.forEach((section) => {
            // Skip the hero — it's always visible on first load
            if (section.id === "hero") return;

            gsap.set(section, {
              clipPath: "polygon(0% 12%, 100% 0%, 100% 100%, 0% 100%)",
              opacity: 0,
              y: 50,
            });

            gsap.to(section, {
              clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
              opacity: 1,
              y: 0,
              duration: 1.2,
              ease: "expo.out",
              scrollTrigger: {
                trigger: section,
                start: "top 90%",
                toggleActions: "play none none none",
              },
            });
          });
        }

        // Refresh scroll triggers once layout is settled
        if (typeof requestIdleCallback !== "undefined") {
          requestIdleCallback(() => ScrollTrigger.refresh());
        } else {
          setTimeout(() => ScrollTrigger.refresh(), 300);
        }
      });

      document.addEventListener("astro:after-swap", () => {
        lenis?.scrollTo(0, { immediate: true });
      });

      // GLOBAL SMOOTH SCROLL INTERCEPTOR
      document.addEventListener(
        "click",
        (e) => {
          const target = e.target as HTMLElement;
          const link = target.closest("a");
          if (!link) return;

          const href = link.getAttribute("href");
          if (!href || !href.includes("#")) return;

          const [pathStr, hashStr] = href.split("#");
          if (!hashStr) return;

          const currentPath = window.location.pathname;
          const isCurrentPage =
            pathStr === "" ||
            pathStr === currentPath ||
            (pathStr === "/" && currentPath === "/");

          if (isCurrentPage) {
            const el = document.getElementById(hashStr);
            if (el) {
              e.preventDefault();
              e.stopPropagation();
              e.stopImmediatePropagation();

              const navbarHeight = window.innerWidth >= 768 ? -96 : -80;
              lenis?.scrollTo(el, {
                offset: navbarHeight,
                duration: 1.5,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
              });
            }
          }
        },
        { capture: true },
      );
    </script>
  </body>
</html>
