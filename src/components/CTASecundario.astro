---
/**
 * CTASecundario — Section post-Portfolio
 * Contrasting brand-black background, brutalist golden-ratio layout.
 * CTA links to WhatsApp with a predefined message.
 */

const WA_PHONE = "34600088257";
const WA_MESSAGE = encodeURIComponent(
  "Hola Humanoides & Asociados, acabo de ver su portfolio y me interesa trabajar con ustedes. ¿Podemos hablar?",
);
const WA_URL = `https://api.whatsapp.com/send?phone=${WA_PHONE}&text=${WA_MESSAGE}`;
---

<section
  id="cta-secundario"
  class="w-full border-y border-brand-red relative overflow-hidden"
  aria-label="Llamada a la acción — Trabajar juntos"
>
  <!-- Animated background -->
  <img src="/cta.webp" alt="" aria-hidden="true" class="cta-bg-anim" />
  <div class="w-full max-w-[1440px] mx-auto px-6 py-16 md:py-24 relative z-10">
    <!-- Ghost number — decorative, patrón establecido -->
    <span
      id="cta-ghost-num"
      class="absolute right-6 top-1/2 -translate-y-1/2 font-sans font-100 select-none pointer-events-none tabular-nums text-brand-black/10 leading-none will-change-transform"
      style="font-size: clamp(8rem, 20vw, 18rem);"
      aria-hidden="true">02</span
    >

    <!-- Golden ratio grid: ~61.8% text / ~38.2% action -->
    <div
      class="relative z-10 grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-center"
    >
      <!-- LEFT COLUMN: ~61.8% (3/5 cols) -->
      <div class="lg:col-span-3 flex flex-col gap-6">
        <!-- Label -->
        <span
          class="text-[10px] font-sans font-bold tracking-[0.3em] uppercase text-brand-gray cta-reveal"
        >
          ¿Listo para el siguiente nivel?
        </span>

        <!-- Heading -->
        <h2
          id="cta-heading"
          class="font-sans font-900 text-brand-gray uppercase leading-none tracking-tight cta-reveal"
          style="font-size: clamp(2.5rem, 7vw, 7rem); letter-spacing: -0.04em; transition-delay: 0.08s;"
        >
          ¿Deseas potenciar<br />
          tu marca?
        </h2>

        <!-- Body -->
        <p
          class="font-sans font-400 text-brand-gray max-w-md cta-reveal"
          style="font-size: clamp(0.95rem, 1.5vw, 1.25rem); line-height: 1.4; transition-delay: 0.16s;"
        >
          Cuéntanos tu proyecto. En 48&nbsp;h tienes una primera propuesta sobre
          la mesa.
        </p>
      </div>

      <!-- RIGHT COLUMN: ~38.2% (2/5 cols) -->
      <div
        class="lg:col-span-2 flex flex-col gap-6 items-start lg:items-end cta-reveal"
        style="transition-delay: 0.24s;"
      >
        <!-- Divider line (desktop) -->
        <div class="hidden lg:block w-full h-px bg-brand-black/20 mb-2"></div>

        <!-- CTA Button -->
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-10 py-6 bg-brand-black text-brand-gray font-bold min-h-[44px] w-full lg:w-auto justify-center lg:justify-start"
          style="font-size: clamp(0.875rem, 1.2vw, 1.125rem); transition: background 0.08s linear, color 0.08s linear;"
          aria-label="Contactar por WhatsApp"
        >
          <span>Empezar Conversación</span>
          <!-- Arrow -->
          <svg
            class="w-4 h-4 shrink-0 transform group-hover:translate-x-1 transition-transform duration-150"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path d="M7 17L17 7M17 7H7M17 7V17"></path>
          </svg>
        </a>

        <!-- Meta info -->
        <p
          class="text-[10px] font-sans font-bold tracking-[0.2em] uppercase text-brand-gray/50"
        >
          Respuesta en &lt; 48&nbsp;h
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── CTA Background Animation ──────────────────────────────────────────────
       Edita estas variables para controlar la imagen de fondo animada:
       --cta-bg-object-position : punto focal del recorte (ej. "center", "top right")
       --cta-bg-scale           : zoom extra sobre el cover base (ej. 1.05 para un 5% zoom)
       --cta-bg-opacity         : transparencia (0 = invisible, 1 = sólida)
       --cta-bg-blend           : modo de mezcla CSS (normal, multiply, overlay…)
    ─────────────────────────────────────────────────────────────────────────── */
  #cta-secundario {
    --cta-bg-object-position: center center;
    --cta-bg-scale: 1;
    --cta-bg-opacity: 0.35;
    --cta-bg-blend: normal;
    background-color: var(--color-brand-red, #fa2a2a);
  }
  .cta-bg-anim {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--cta-bg-object-position);
    transform: scale(var(--cta-bg-scale));
    opacity: var(--cta-bg-opacity);
    mix-blend-mode: var(--cta-bg-blend);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* ─── Reveal animation ───────────────────────────────────────────────────── */
  .cta-reveal {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .cta-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const section = document.getElementById("cta-secundario");
    const ghostNum = document.getElementById(
      "cta-ghost-num",
    ) as HTMLElement | null;

    // Parallax on ghost number
    if (!prefersReduced && section && ghostNum) {
      const onScroll = () => {
        requestAnimationFrame(() => {
          const rect = section.getBoundingClientRect();
          const vh = window.innerHeight;
          const progress = 1 - rect.top / vh;
          if (progress > -0.5 && progress < 1.8) {
            ghostNum.style.transform = `translateY(calc(-50% + ${progress * 60}px))`;
          }
        });
      };
      window.addEventListener("scroll", onScroll, { passive: true });
    }

    // Staggered reveal for all .cta-reveal elements
    const reveals = document.querySelectorAll<HTMLElement>(
      "#cta-secundario .cta-reveal",
    );

    if (!prefersReduced) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              (entry.target as HTMLElement).classList.add("is-visible");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: "0px 0px -5% 0px" },
      );
      // Use rAF to ensure layout is settled before observing
      requestAnimationFrame(() => {
        reveals.forEach((el) => io.observe(el));
      });
    } else {
      // No-JS / reduced-motion: make everything visible immediately
      reveals.forEach((el) => el.classList.add("is-visible"));
    }
  });
</script>
