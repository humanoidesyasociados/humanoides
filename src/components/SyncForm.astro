---

---

<form id="sync-form" class="w-full flex flex-col gap-4 md:gap-6 font-sans">
  <div class="flex flex-col gap-1.5">
    <label
      for="name"
      class="text-[10px] md:text-xs font-sans font-bold tracking-normal text-brand-black uppercase"
      >Nombre / Empresa</label
    >
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full bg-transparent border-b border-brand-black py-3 md:py-2 text-brand-black focus:outline-none focus:border-brand-red transition-colors text-sm placeholder:text-brand-black font-semibold"
      placeholder=""
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label
      for="email"
      class="text-[10px] md:text-xs font-sans font-bold tracking-normal text-brand-black uppercase"
      >Email</label
    >
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full bg-transparent border-b border-brand-black py-3 md:py-2 text-brand-black focus:outline-none focus:border-brand-red transition-colors text-sm placeholder:text-brand-black font-semibold"
      placeholder=""
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label
      for="description"
      class="text-[10px] md:text-xs font-sans font-bold tracking-normal text-brand-black uppercase"
      >Mensaje</label
    >
    <textarea
      id="description"
      name="description"
      rows="3"
      required
      class="w-full bg-transparent border-b border-brand-black py-3 md:py-2 text-brand-black focus:outline-none focus:border-brand-red transition-colors text-sm resize-none placeholder:text-brand-black/30 font-semibold"
      placeholder=""></textarea>
  </div>

  <div class="flex flex-col gap-3">
    <button
      type="submit"
      class="mt-2 md:mt-4 w-full md:w-auto self-start inline-flex items-center justify-center px-8 py-3.5 md:py-4 bg-brand-black text-brand-gray text-sm font-bold tracking-normal hover:bg-brand-red hover:text-brand-gray min-h-[44px]"
      style="transition: background 0.08s linear, color 0.08s linear;"
    >
      Iniciar Charla
    </button>
  </div>
</form>

<script>
  const form = document.getElementById("sync-form") as HTMLFormElement;
  const descriptionInput = document.getElementById(
    "description",
  ) as HTMLTextAreaElement;

  // Handle query parameter for auto-filling description
  const updateDescriptionFromQuery = () => {
    const urlParams = new URLSearchParams(window.location.search);
    const subject = urlParams.get("subject");
    if (subject && descriptionInput) {
      descriptionInput.value = `Interés en servicio/programa: ${subject}\n\n`;
      // Smooth scroll to form if subject is present
      const contactSection = document.getElementById("contacto");
      if (contactSection) {
        contactSection.scrollIntoView({ behavior: "smooth" });
      }
    }
  };

  // Run on load
  updateDescriptionFromQuery();

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const name = formData.get("name")?.toString() || "";
    const email = formData.get("email")?.toString() || "";
    const description = formData.get("description")?.toString() || "";

    // Save final lead in the background
    fetch("/api/leads", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name, email, description, isPartial: false }),
    }).catch((err) => console.error("Error guardando el lead:", err));

    const text = `hola soy ${name}(${email}) y este es mi mensaje: ${description}`;
    const encodedText = encodeURIComponent(text);
    const whatsappUrl = `https://api.whatsapp.com/send?phone=34600088257&text=${encodedText}`;

    window.open(whatsappUrl, "_blank");

    // Optional: clear form
    form.reset();
  });

  // Capture lead on email blur (Abandonment Capture)
  const nameInput = document.getElementById("name") as HTMLInputElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;

  let lastCapturedEmail = "";

  emailInput?.addEventListener("blur", () => {
    const email = emailInput.value.trim();
    if (email && email.includes("@") && email !== lastCapturedEmail) {
      lastCapturedEmail = email;
      const name = nameInput?.value.trim() || "";
      const description = descriptionInput?.value.trim() || "";

      fetch("/api/leads", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, email, description, isPartial: true }),
      }).catch((err) => console.error("Error guardando borrador:", err));
    }
  });
</script>
